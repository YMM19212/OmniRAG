# Copy this file to .env and adjust the values for your environment.
# Docker Milvus: keep OMNIRAG_MILVUS_URI empty and set host/port.
# Milvus Lite: set OMNIRAG_MILVUS_URI to a local .db path and host/port will be ignored.

OMNIRAG_EMBEDDING_API_URL=https://api.jina.ai/v1/embeddings
OMNIRAG_EMBEDDING_MODEL_NAME=jina-embeddings-v4
OMNIRAG_EMBEDDING_API_KEY=jina_21cdf56ab4c54966b0330445dc227ed6HH6fZPIj6SBgXLxdutPnMx2XUSt1
JINA_API_KEY=jina_6b5c2bed5a33425d9330859fb4ebc90e4SjNTVOc2jPqsaxv_J86jZjkRfIa
OMNIRAG_EMBEDDING_TASK=text-matching

OMNIRAG_MILVUS_URI=
OMNIRAG_MILVUS_HOST=127.0.0.1
OMNIRAG_MILVUS_PORT=19530
OMNIRAG_COLLECTION_NAME=multimodal_kb

OMNIRAG_VECTOR_DIM=2048
OMNIRAG_INDEX_TYPE=HNSW
OMNIRAG_METRIC_TYPE=COSINE
OMNIRAG_INDEX_M=16
OMNIRAG_INDEX_EF_CONSTRUCTION=200

OMNIRAG_ENABLE_DEDUPLICATION=true
OMNIRAG_DEDUP_MODE=semantic
OMNIRAG_SIMILARITY_THRESHOLD=0.95
OMNIRAG_CHECK_EXISTING_BEFORE_INSERT=true

OMNIRAG_VIDEO_SAMPLE_FRAMES=8
OMNIRAG_VIDEO_SAMPLE_STRATEGY=uniform
OMNIRAG_VIDEO_MAX_DURATION=300

OMNIRAG_MAX_CONCURRENT_EMBEDS=8
OMNIRAG_MAX_CONCURRENT_FRAMES=8
OMNIRAG_HTTP_TIMEOUT_TOTAL=60
OMNIRAG_HTTP_TIMEOUT_CONNECT=10
